{
  "name": "memboux",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/app-midnight.css --minify",
    "build": "npm run build:css",
    "deploy": "npm run build && wrangler deploy",
    "check": "npm run build && npm run typecheck && npm test && npm run check:types && npm run check:bundle",
    "check:types": "wrangler types --check",
    "check:bundle": "wrangler deploy --dry-run",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local": "wrangler d1 migrations apply memboux-db --local",
    "db:remote": "wrangler d1 migrations apply memboux-db --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "exifr": "^7.1.3",
    "hono": "^4.12.30",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@tailwindcss/cli": "^4.3.2",
    "@types/qrcode": "^1.5.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
